{
  "name": "task-garden",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "taskgarden": "./dist/cli/bin.js"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "vite build && bun run build:cli",
    "build:cli": "bun build cli/bin.ts --target=bun --outfile=dist/cli/bin.js",
    "start": "bun cli/bin.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc --noEmit --project cli/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@xyflow/react": "^12.3.6",
    "chokidar": "^4",
    "graphology": "^0.26.0",
    "graphology-dag": "^0.4.1",
    "graphology-metrics": "^2.2.0",
    "graphology-types": "^0.24.8",
    "open": "^10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hotkeys-hook": "^5.2.4",
    "yaml": "^2.7.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.17",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "bun-types": "^1.1",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  }
}
